<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Motivacija za zadnji ispit!</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #74ebd5 0%, #9face6 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #333;
            overflow: hidden;
            position: relative;
        }

        /* Lebdeći elementi u pozadini */
        .floating-bg {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .floating-bg span {
            position: absolute;
            font-size: 2rem;
            animation: float 6s ease-in-out infinite;
            opacity: 0.6;
        }

        .floating-bg span:nth-child(1) { top: 10%; left: 10%; animation-delay: 0s; }
        .floating-bg span:nth-child(2) { top: 20%; left: 80%; animation-delay: 1s; }
        .floating-bg span:nth-child(3) { top: 70%; left: 15%; animation-delay: 2s; }
        .floating-bg span:nth-child(4) { top: 80%; left: 75%; animation-delay: 3s; }
        .floating-bg span:nth-child(5) { top: 40%; left: 50%; animation-delay: 1.5s; }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(10deg); }
        }

        /* Glavni kontejner */
        .container {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 40px;
            max-width: 600px;
            width: 90%;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            z-index: 1;
        }

        /* Tajmer */
        .timer-section h2 {
            font-size: 1.2rem;
            color: #555;
            margin-bottom: 15px;
        }

        .countdown {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 30px;
        }

        .time-box {
            background: #fff;
            padding: 10px 15px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            min-width: 70px;
        }

        .time-box span {
            font-size: 2rem;
            font-weight: 800;
            color: #ff6b6b;
        }

        .time-box p {
            font-size: 0.8rem;
            color: #888;
            text-transform: uppercase;
        }

        /* Tekst i naslov */
        h1.bounce {
            font-size: 2rem;
            color: #2d3436;
            margin-bottom: 15px;
            animation: bounceIn 1s cubic-bezier(0.28, 0.84, 0.42, 1);
        }

        @keyframes bounceIn {
            0% { transform: scale(0); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        .intro-text {
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 30px;
            color: #444;
        }

        /* Tabela */
        .table-container h3 {
            margin-bottom: 15px;
            color: #2d3436;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
            background: #fff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        th, td {
            padding: 12px;
            border-bottom: 1px solid #eee;
        }

        th {
            background: #6c5ce7;
            color: white;
            font-weight: 600;
        }

        tr:last-child td { border-bottom: none; }
        
        tr:hover { background: #f8f9fa; }

        .desetka {
            font-weight: 800;
            color: #d63031;
            background: #ffeaa7 !important;
        }

        /* Fusnota */
        .disclaimer {
            font-size: 0.9rem;
            font-style: italic;
            color: #636e72;
            margin-top: 15px;
        }
    </style>
</head>
<body>

    <div class="floating-bg">
        <span>🎓</span><span>💸</span><span>👟</span><span>📚</span><span>🎉</span>
    </div>

    <div class="container">
        <div class="timer-section">
            <h2>Do slobode ostalo je još samo:</h2>
            <div id="countdown" class="countdown">
                <div class="time-box"><span id="days">00</span><p>Dana</p></div>
                <div class="time-box"><span id="hours">00</span><p>Sati</p></div>
                <div class="time-box"><span id="minutes">00</span><p>Minuta</p></div>
                <div class="time-box"><span id="seconds">00</span><p>Sekundi</p></div>
            </div>
        </div>

        <div class="content-section">
            <h1 class="bounce">Ajmo, još samo taj jedan! 💪</h1>
            <p class="intro-text">
                Knjigu u šake, jer ovaj zadnji ispit ne stoji samo između tebe i diplome... stoji između tebe i <strong>novih patika</strong> (bile to Skechers, Lotto ili neke potpuno treće)!
            </p>

            <div class="table-container">
                <h3>Zvanična "Fond za patike" tarifa:</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Ocena na ispitu</th>
                            <th>Budžet za patike (RSD)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>6</td><td>6.000</td></tr>
                        <tr><td>7</td><td>7.000</td></tr>
                        <tr><td>8</td><td>8.000</td></tr>
                        <tr><td>9</td><td>9.000</td></tr>
                        <tr class="desetka"><td>10</td><td>10.000 👑</td></tr>
                    </tbody>
                </table>
                <p class="disclaimer">* U zavisnosti od raspoloženja (i koliko me oduševiš), vrednost kupona može i da poraste ;)</p>
            </div>
        </div>
    </div>

    <script>
        // Postavi datum ispita: 25. maj 2026. u 09:00:00
        const examDate = new Date("May 25, 2026 09:00:00").getTime();

        const timer = setInterval(function() {
            const now = new Date().getTime();
            const distance = examDate - now;

            if (distance < 0) {
                clearInterval(timer);
                document.getElementById("countdown").innerHTML = "<h2>Ispit je počeo! Srećno! 🍀</h2>";
                return;
            }

            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            // Formatiranje da uvek ima dve cifre (npr. 05 umesto 5)
            document.getElementById("days").innerText = days.toString().padStart(2, '0');
            document.getElementById("hours").innerText = hours.toString().padStart(2, '0');
            document.getElementById("minutes").innerText = minutes.toString().padStart(2, '0');
            document.getElementById("seconds").innerText = seconds.toString().padStart(2, '0');
            
        }, 1000);
    </script>
</body>
</html>
